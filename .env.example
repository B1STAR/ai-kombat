# ============================================
# AI KOMBAT - Environment Variables Example
# ============================================
# Copy this file to `.env` (locally) and fill in the values
# NEVER commit `.env` to git (it's in .gitignore)
# For production, set these in your hosting platform's dashboard
# ============================================

# ============ TELEGRAM ============
# Get from @BotFather on Telegram after /newbot and /newapp
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=AIKombatBot

# ============ BACKEND (apps/api) ============
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ============ DATABASE (Supabase) ============
# Get from Supabase dashboard: Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ============ CACHE / RATE LIMITING (Upstash) ============
# Get from Upstash console after creating a Redis database
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============ AUTH ============
# Generate a strong random string (used for any additional session signing)
JWT_SECRET=change-me-in-production-please-use-a-long-random-string

# ============ MONITORING (optional) ============
SENTRY_DSN=
LOGFLARE_API_KEY=

# ============ ADS (Phase 2+) ============
# Get from @AdsgramBot on Telegram
ADSGRAM_BLOCK_ID=

# ============ PAYMENTS (Phase 3+) ============
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ============ FRONTEND (apps/web) ============
# These are prefixed with NEXT_PUBLIC_ so they're available in the browser
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=AIKombatBot
NEXT_PUBLIC_SENTRY_DSN=
